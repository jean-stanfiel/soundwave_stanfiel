<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-header bg-transparent text-center pt-4">
                <i class="bi bi-pencil-square display-3 text-warning"></i>
                <h2 class="mt-2">Editar Artista</h2>
                <p class="text-muted">Actualiza la información del artista</p>
            </div>
            <div class="card-body p-4">
                <form action="/soundwave/artistas/editar/{{artista.id}}" method="POST">
                    <div class="mb-3">
                        <label class="form-label fw-bold">
                            <i class="bi bi-mic"></i> Nombre del Artista
                        </label>
                        <input type="text" class="form-control" name="nombre" value="{{artista.nombre}}" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">
                            <i class="bi bi-music-note"></i> Género Musical
                        </label>
                        <input type="text" class="form-control" name="genero" value="{{artista.genero}}" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">
                            <i class="bi bi-geo-alt"></i> País de Origen
                        </label>
                        <input type="text" class="form-control" name="pais" value="{{artista.pais}}" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">
                            <i class="bi bi-image"></i> URL de Imagen
                        </label>
                        <input type="url" class="form-control" name="imagen" value="{{artista.imagen}}" placeholder="https://ejemplo.com/imagen.jpg">
                        <small class="text-muted">Deja vacío para usar imagen por defecto</small>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-warning btn-lg">
                            <i class="bi bi-save"></i> Actualizar Artista
                        </button>
                        <a href="/soundwave" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

{{#if artista.imagen}}
<div class="row justify-content-center mt-4">
    <div class="col-md-6 text-center">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6 class="text-muted">Vista previa de la imagen actual:</h6>
                <img src="{{artista.imagen}}" alt="{{artista.nombre}}" style="max-width: 200px; max-height: 200px; border-radius: 10px;">
            </div>
        </div>
    </div>
</div>
{{/if}}