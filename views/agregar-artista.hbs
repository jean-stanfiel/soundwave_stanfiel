<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-header bg-transparent text-center pt-4">
                <i class="bi bi-person-plus-fill display-3 text-primary"></i>
                <h2 class="mt-2">Agregar Nuevo Artista</h2>
            </div>
            <div class="card-body p-4">
                <form action="/soundwave/artistas/agregar" method="POST">
                    <div class="mb-3">
                        <label class="form-label fw-bold"><i class="bi bi-mic"></i> Nombre</label>
                        <input type="text" class="form-control" name="nombre" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold"><i class="bi bi-music-note"></i> Género</label>
                        <input type="text" class="form-control" name="genero" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold"><i class="bi bi-geo-alt"></i> País</label>
                        <input type="text" class="form-control" name="pais" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold"><i class="bi bi-image"></i> URL Imagen</label>
                        <input type="url" class="form-control" name="imagen" placeholder="https://ejemplo.com/imagen.jpg">
                    </div>
                    <button type="submit" class="btn btn-soundwave w-100 py-2">
                        <i class="bi bi-save"></i> Guardar Artista
                    </button>
                    <a href="/soundwave" class="btn btn-outline-secondary w-100 mt-2">
                        <i class="bi bi-arrow-left"></i> Volver
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>