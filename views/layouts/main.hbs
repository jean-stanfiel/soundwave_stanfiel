<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} | SoundWave 🎵</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark navbar-soundwave sticky-top">
        <div class="container">
            <a class="navbar-brand" href="/soundwave">
                <i class="bi bi-music-note-beamed"></i> SoundWave
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/soundwave">
                            <i class="bi bi-house-door"></i> Inicio
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/soundwave/artistas/agregar">
                            <i class="bi bi-person-plus"></i> Agregar Artista
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/api/artistas" target="_blank">
                            <i class="bi bi-code-slash"></i> API
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container mt-4 fade-in">
        {{{body}}}
    </main>

    <footer class="text-center text-white mt-5 py-3" style="background: var(--primary-gradient);">
        <p class="mb-0">
            <i class="bi bi-music-player"></i> SoundWave - Proyecto Full Stack JavaScript | Estudiantes Coderhouse
        </p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/scripts.js"></script>
</body>
</html>